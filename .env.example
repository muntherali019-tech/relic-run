# Copy this file to ".env" and paste your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the backend proxy runs on (Vite proxies /api here in dev)
PORT=8787

# Secret used to sign auth tokens in the built-in dev auth.
# Set a long random value in production (or move auth to a managed provider).
AUTH_SECRET=change-me-to-a-long-random-string

# ---- AI models (optional) ----
# Default Claude model for all AI features, plus per-feature overrides. The
# client sends a feature hint (questions, mark, solve, chat, language, course,
# exam, goal, note, voice, translate); MODEL_<FEATURE> routes just that feature.
# Example: send high-volume, low-stakes work to the cheaper Haiku model.
# MODEL_DEFAULT=claude-sonnet-4-6
# MODEL_TRANSLATE=claude-haiku-4-5
# MODEL_VOICE=claude-haiku-4-5
# Extra models clients may request directly (comma-separated allowlist).
# ALLOWED_MODELS=claude-sonnet-4-6,claude-haiku-4-5
# Rate limits and CORS hardening:
# CORS_ORIGIN=https://your-domain.example

# ---- Premium voice (optional) ----
# Add an ElevenLabs key to enable Mochi's premium cloud voice. Leave blank to
# use the free on-device voice. Pick a child-friendly voice id from your account.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ---- Build-time (frontend) variables ----
# Where the app finds the backend API. Leave unset in dev (proxies to /api).
# In production set to your deployed API, e.g. https://api.your-domain.example/api
# VITE_API_BASE=

# Voice backend: "device" (free, on-device) or "cloud" (premium via /api/tts).
# VITE_TTS=device

# Billing mode: "mock" (dev, instant unlock) or "revenuecat" (production).
# VITE_BILLING=mock
# Stripe publishable key for the web build (client-safe by design; the test
# key lives in .env.web — set your live pk_live_… key before launch).
# VITE_STRIPE_PUBLISHABLE_KEY=
# RevenueCat public SDK key (required when VITE_BILLING=revenuecat).
# VITE_REVENUECAT_KEY=

# Public URL of your hosted privacy policy (used by the in-app Privacy links).
# VITE_PRIVACY_URL=https://your-domain.example/privacy

# ---- Weekly parent emails (optional) ----
# Provider: "console" (default, just logs), "resend", or "sendgrid".
EMAIL_PROVIDER=console
EMAIL_FROM=Education Academy <noreply@your-domain.example>
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# Protect the cron endpoint; send this as the x-cron-secret header.
# CRON_SECRET=
# Set to 1 to run the weekly check inside the server process (no external cron needed).
# WEEKLY_EMAILS_INPROCESS=0
# Secret for the admin report endpoints (preview/trigger). Send as the x-admin-secret header.
# ADMIN_SECRET=

# Public Play Store listing URL (used by the in-app "Rate" fallback on web).
# VITE_PLAY_URL=https://play.google.com/store/apps/details?id=com.whiskeracademy.app

# ---- Web build payments (Stripe) ----
# Used by the Express server for the WEB build's checkout + billing portal.
STRIPE_SECRET_KEY=
STRIPE_PRICE_JUNIOR=
STRIPE_PRICE_ADULT=
STRIPE_WEBHOOK_SECRET=
# Where Checkout returns the user (your deployed web URL):
PUBLIC_WEB_URL=http://localhost:5173

# Build flags (usually set via .env.web / .env.app, not here):
# VITE_PLATFORM=web|app
# VITE_BILLING=mock|revenuecat|stripe   (blank = mock in dev, real in production builds)
# VITE_REVENUECAT_KEY=goog_xxx          (app build only)

# ---------- Durable database (optional) ----------
# Leave blank to use the JSON file store (fine locally and on hosts with a persistent disk).
# Set this to a Postgres connection string to keep accounts across restarts/redeploys on
# ephemeral hosts. Then run: npm install pg
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ---------- Public site URL for sharing (optional) ----------
# Canonical URL used when the app shares a link via the device share sheet
# (src/lib/share.js). Leave blank to fall back to the current page's origin.
# Set to your deployed website to make shared links always point at it.
# VITE_PUBLIC_URL=https://your-domain.example

# ---------- Legal page links (optional) ----------
# The app links to /privacy and /terms on the same domain by default (served by the server).
# Override only if you host them elsewhere:
# VITE_PRIVACY_URL=/privacy
# VITE_TERMS_URL=/terms
