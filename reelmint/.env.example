# Copy to .env for local development:  cp .env.example .env

# --- AI (Anthropic) ---
# Your Anthropic API key. Get one at https://console.anthropic.com
# If left blank, Reelmint runs in a built-in DEMO mode (no real AI calls).
ANTHROPIC_API_KEY=
# Quality model for storyboards, edits, vision and image specs.
AI_MODEL=claude-opus-4-8
# Fast model for high-volume, low-stakes copy (captions, Hook Lab). Cheaper and
# quicker without hurting the headline output.
AI_MODEL_FAST=claude-haiku-4-5

# --- Server ---
PORT=3000
# Storage: set DATABASE_URL to use Postgres (durable, multi-instance).
# Leave it blank to use a local JSON file at DATA_DIR (fine for local/demo).
DATABASE_URL=
# Set to "disable" for a local Postgres without SSL (default uses SSL when DATABASE_URL is set).
PGSSL=
# Where the JSON store is written when DATABASE_URL is not set.
DATA_DIR=./.data
# Secret used to sign login tokens. REQUIRED in production — set a long random value.
AUTH_SECRET=
# Set to 1 to disable the free-tier watermark everywhere.
REELMINT_NO_WATERMARK=

# --- Photoreal image generation (optional) ---
# Option A: OpenAI Images API
IMAGE_PROVIDER=            # set to "openai" to enable
OPENAI_API_KEY=
IMAGE_MODEL=gpt-image-1
# Option B: any custom endpoint that takes {prompt,width,height} -> {url} or {b64}
IMAGE_API_URL=
IMAGE_API_KEY=

# --- Billing (Stripe, optional) ---
# Create products/prices in the Stripe dashboard, then paste the price IDs.
STRIPE_SECRET_KEY=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_STUDIO=
# From `stripe listen` (local) or the webhook endpoint settings (prod).
STRIPE_WEBHOOK_SECRET=
